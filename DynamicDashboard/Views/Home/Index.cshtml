@model DataTable
@using System.Data;
@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Index</title>
    <style type="text/css">
        body { font-family: Arial, Helvetica, sans-serif; font-size: 10px; }
        table { border-spacing: 0; border-collapse: separate; border-radius: 10px; --border: 1px solid black; border: var(--border); overflow: hidden; }
        table th { background-color: #c1c1c1; }
        table th, table td { padding: 8px; }
        table tr:last-child, table tr:last-child > td { background-color: orange; color: black; }
        table tr td:last-child { background-color: orange; color: black; }
        table th:not(:last-child), table td:not(:last-child) { border-right: 1px solid black; }
        table tr:not(:last-child) > th, table tr:not(:last-child) > td { border-bottom: 1px solid black; }
    </style>
</head>
<body>
    @if (Model != null)
    {
        <table align="center">
            <tr>
                @foreach (DataColumn dc in Model.Columns)
                {
                    <th>
                        @if (!dc.ColumnName.Equals("Total"))
                        {
                            <span>@dc.ColumnName</span>
                        }
                    </th>
                }
            </tr>
            @foreach (DataRow dr in Model.Rows)
            {
                <tr>
                    @foreach (DataColumn dc in Model.Columns)
                    {
                        <td>
                            @if (dr[dc.ColumnName] != DBNull.Value)
                            {
                                <span>@dr[dc.ColumnName]</span>
                            }
                            else
                            {
                                <span style="color:red;">0</span>
                            }
                        </td>
                    }
                </tr>
            }
        </table>
    }
</body>
</html>
